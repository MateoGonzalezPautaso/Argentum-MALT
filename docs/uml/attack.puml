@startuml
title Flujo de Ataque Jugador → NPC

actor Usuario
participant "GameController\n(client/screen/)" as GC
participant "command_queue" as CQ
participant "Client Sender\n(Thread)" as CS
participant TCP
participant "Server Receiver\n(Thread)" as SR
participant "Server Sender\n(Thread)" as SS
participant "input_queue" as IQ
participant "GameLoop\n(Thread)" as GL
participant Game
participant CombatController as CC
participant EnemyNpc as NPC

Usuario -> GC: presiona tecla ataque
GC -> CQ: push(AttackCmd{target_id})
CQ -> CS: pop()
CS -> TCP: ClientProtocol::send_attack()
TCP -> SR: bytes
SR -> IQ: push(PlayerCommand{player_id, AttackCmd})
IQ -> GL: try_pop()
GL -> Game: process_command(player_id, cmd)
Game -> CC: melee_attack(attacker, target_id, tick)
CC -> NPC: try_attack(tick, cooldown)
NPC -> CC: true
CC -> CC: calcular daño\n(damage * str * clan_bonus - defense)
CC -> NPC: take_damage(damage)
NPC -> CC: is_dead()? → kill()
CC -> CC: construye DamageDealtEvent / DamageReceivedEvent\ny EntityDiedEvent (si mata) directamente
CC -> Game: CommandResult\n{private_events, broadcast_events, ...}
Game -> GL: CommandResult
GL -> GL: despachar eventos a colas de salida
SS -> TCP: ServerProtocol::send_event(DamageDealtEvent)
TCP -> Client: bytes

note over Usuario, TCP
  El cliente recibe DamageDealtEvent,
  DamageReceivedEvent, EntityDiedEvent (si mata)
  y actualiza UI (HP, EXP, SFX)
end note
@enduml