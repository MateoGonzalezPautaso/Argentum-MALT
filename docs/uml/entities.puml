@startuml
title Jerarquía de Entidades

class Entity {
  - hp_current: int
  - hp_max: int
  - name: string
  - pos: Position
  - dir: Direction
  - level: int
  - sprite_id: uint16_t
  - speed: int
  + take_damage(damage: int)
  + is_dead(): bool
  + try_attack(tick: int, cooldown: int): bool
  + kill(): EnemyDrop
  + get_dir(): Direction
  + set_dir(d: Direction)
}

class Player {
  - id: uint16_t
  - race: Race
  - player_class: PlayerClass
  - experience: int
  - gold: int
  - mana_current: int
  - mana_max: int
  - strength: int
  - agility: int
  - inv: PlayerInventory
  - bank_inv: Inventory
  - bank_gold: int
  - clan_name: string
  + level_up()
  + gain_experience(amount: int)
  + equip(item: ItemSlot)
  + unequip(slot: EquipSlot)
  + heal(amount: int)
  + restore_mana(amount: int)
}

class EnemyNpc {
  - damage: int
  - rng: RNG
  + get_kill_reward(config: NpcDropConfig): EnemyDrop
}

class PlayerInventory {
  - equip: Inventory
  - hp_potions: Inventory
  - mana_potions: Inventory
  + equip_item(slot: ItemSlot): ItemSlot
  + unequip_item(slot: EquipSlot): ItemSlot
  + add_potion(item: ItemSlot)
  + use_hp_potion(): int
  + use_mana_potion(): int
}

class Inventory {
  - slots: vector<ItemSlot>
  - max_slots: int
  + add_item(item: ItemSlot): bool
  + remove_item(slot: int): ItemSlot
  + get_item(slot: int): ItemSlot
  + is_full(): bool
}

class PlayerRegistry {
  - players: map<uint16_t, Player>&
  + ids_on_map(map_name): vector<uint16_t>
  + get(id: uint16_t): Player&
  + count(): size_t
}
note bottom of PlayerRegistry
  Wrapper de consulta efímero sobre el
  map<uint16_t, Player> de Game. No es
  dueño de los Player ni un miembro de
  Game: se construye on-the-fly como
  PlayerRegistry(players).
end note

class Game {
  - players: map<uint16_t, Player>
  - enemy_npcs: map<uint16_t, EnemyNpc>
  - maps: unordered_map<string, Map>
  - combat_controller: CombatController
  - clan_manager: ClanManager
  + process_command(id: uint16_t, cmd: ClientCommand): CommandResult
  + tick(): CommandResult
}
note bottom of Game
  Además compone 12 servicios
  especializados (BankService,
  SpawnService, SpellService, ...).
  Ver game_services.puml.
end note

class CombatController {
  + melee_attack(attacker_id, target_id, tick): CommandResult
  + update_npc_ai(current_tick): CommandResult
}

class ClanManager {
  + create_clan(founder, name): CommandResult
  + request_join(applicant, clan): CommandResult
  + accept_member(founder, target): CommandResult
  + kick_member(founder, target): CommandResult
}

Entity <|-- Player
Entity <|-- EnemyNpc
Player *-- PlayerInventory
PlayerInventory *-- Inventory
Game "1" o-- "*" Player : players
Game "1" o-- "*" EnemyNpc : enemy_npcs
Game "1" *-- "1" CombatController
Game "1" *-- "1" ClanManager
Game ..> PlayerRegistry : <<envuelve players>>
CombatController ..> EnemyNpc : opera (por referencia)
@enduml